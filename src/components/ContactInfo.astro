---

<div id="contact-info" class="rounded-2xl bg-gov-navy p-8 text-white">
  <h2 class="text-xl font-bold text-white">Informacion de Contacto</h2>
  <p class="mt-2 text-sm text-white/70">
    Encuentranos en la oficina o ponte en contacto a traves de otros canales.
  </p>

  <div class="mt-6 space-y-5">
    <div>
      <h3 class="text-sm font-semibold text-muni-gold">Direccion</h3>
      <p class="mt-1 text-sm text-white/80">Calle Centrar Este, 1 y 2 ave., Barrio Las Acacias</p>
    </div>
    <div>
      <h3 class="text-sm font-semibold text-muni-gold">Telefono</h3>
      <p class="mt-1 text-sm text-white/80">+504 2438-9111</p>
    </div>
    <div>
      <h3 class="text-sm font-semibold text-muni-gold">Correo Electronico</h3>
      <p class="mt-1 text-sm text-white/80">municipalidadbonitoriental@gmail.com</p>
    </div>
  </div>
</div>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('#contact-info', {
    scrollTrigger: { trigger: '#contact-info', start: 'top 80%' },
    x: 60, duration: 0.8, ease: 'power2.out',
  });
</script>
