---
import { Icon } from 'astro-icon/components';

interface Props {
  label: string;
  href: string;
}

const { label, href } = Astro.props;
---

<a
  href={href}
  download
  class="inline-flex items-center gap-2 rounded-full border border-border-warm bg-white px-6 py-2.5 text-sm font-medium text-gov-navy hover:bg-bg-warm transition-all duration-300"
>
  <Icon name="lucide:download" class="h-5 w-5" />
  {label}
</a>
