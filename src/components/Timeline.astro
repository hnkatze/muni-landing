---
const milestones = [
  { year: '1987', title: 'Primera Corporación', desc: 'Se nombra la primera corporación municipal, encabezada por Heriberto Rodríguez.' },
  { year: '1989', title: 'Primer Alcalde Electo', desc: 'Tulio Turcios Romero se convierte en el primer alcalde elegido democráticamente.' },
  { year: '1994', title: 'Edificio Municipal', desc: 'Se funda el edificio municipal bajo la corporación de Heriberto Rodríguez.' },
  { year: '2002', title: 'Expansión Vial', desc: 'Habilitación de calles en Corocito, La Esperanza, Palmichal, Bridge y El Cinco.' },
  { year: '2006', title: 'Boulevard y Expansión', desc: 'Construcción del Boulevard Clemente Cardona y segunda planta de la municipalidad.' },
  { year: '2010', title: 'Mercado y Parque', desc: 'Construcción del mercado municipal, culminación del parque y múltiples escuelas.' },
  { year: '2014', title: 'Participación Ciudadana', desc: 'Presupuesto participativo y empoderamiento de organizaciones como AJABO y CCT.' },
];
---

<section id="timeline-section" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
  <div class="text-center mb-14">
    <p class="text-sm font-semibold uppercase tracking-widest text-muni-gold">Desde 1987</p>
    <h2 class="mt-2 text-3xl font-bold text-gov-navy lg:text-4xl">Nuestra Historia</h2>
  </div>

  {/* Desktop: horizontal timeline */}
  <div class="hidden md:block relative">
    {/* Line */}
    <div class="absolute top-6 left-0 right-0 h-0.5 bg-border-warm"></div>

    <div class="grid grid-cols-7 gap-4">
      {milestones.map((m, i) => (
        <div class={`reveal delay-${Math.min(i + 1, 5)} relative flex flex-col items-center text-center`}>
          {/* Dot */}
          <div class="relative z-10 flex h-12 w-12 items-center justify-center rounded-full bg-gov-navy text-white text-sm font-bold shadow-md shadow-gov-navy/20">
            {m.year.slice(2)}
          </div>
          <p class="mt-3 text-xs font-bold text-gov-navy">{m.year}</p>
          <p class="mt-1 text-xs font-semibold text-gov-teal">{m.title}</p>
          <p class="mt-1 text-xs text-text-secondary leading-relaxed">{m.desc}</p>
        </div>
      ))}
    </div>
  </div>

  {/* Mobile: vertical timeline */}
  <div class="md:hidden relative pl-8">
    {/* Vertical line */}
    <div class="absolute top-0 bottom-0 left-3 w-0.5 bg-border-warm"></div>

    <div class="space-y-8">
      {milestones.map((m) => (
        <div class="reveal relative">
          {/* Dot */}
          <div class="absolute -left-8 top-0 flex h-6 w-6 items-center justify-center rounded-full bg-gov-navy text-white text-[10px] font-bold">
            {m.year.slice(2)}
          </div>
          <p class="text-sm font-bold text-gov-navy">{m.year} — {m.title}</p>
          <p class="mt-1 text-sm text-text-secondary leading-relaxed">{m.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
