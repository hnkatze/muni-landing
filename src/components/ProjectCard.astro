---
import type { Proyecto } from '../types';

interface Props {
  proyecto: Proyecto;
}

const { proyecto } = Astro.props;
---

<div class="project-card flex flex-col rounded-2xl bg-white shadow-md border-t-4 border-gov-teal hover:-translate-y-1 hover:shadow-xl transition-all duration-300">
  <div class="flex-1 p-5">
    <h3 class="text-lg font-bold text-gov-navy">{proyecto.titulo}</h3>
    <p class="mt-1 text-xs text-gov-teal font-medium">{proyecto.zonas}</p>
    <p class="mt-3 text-sm text-text-secondary line-clamp-4 max-h-[240px] overflow-hidden">
      {proyecto.descripcion}
    </p>
  </div>
  <div class="border-t border-gray-100 p-4">
    <a
      href={proyecto.enlace}
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm font-semibold text-muni-green hover:text-muni-green-dark transition-colors duration-200"
    >
      Ver Aqui!! →
    </a>
  </div>
</div>
