---
import type { Proyecto } from '../types';

interface Props {
  proyecto: Proyecto;
}

const { proyecto } = Astro.props;
---

<div class="reveal flex flex-col rounded-3xl bg-white border border-border-warm hover:-translate-y-1 hover:shadow-lg hover:shadow-gov-navy/5 transition-all duration-300">
  <div class="flex-1 p-6">
    <h3 class="text-lg font-bold text-gov-navy">{proyecto.titulo}</h3>
    <p class="mt-1 text-xs text-muni-gold font-semibold uppercase tracking-wide">{proyecto.zonas}</p>
    <p class="mt-3 text-sm text-text-secondary leading-relaxed line-clamp-4 max-h-[240px] overflow-hidden">
      {proyecto.descripcion}
    </p>
  </div>
  <div class="border-t border-border-warm p-5">
    <a
      href={proyecto.enlace}
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm font-semibold text-gov-navy hover:text-gov-teal transition-colors duration-200"
    >
      Ver Proyecto →
    </a>
  </div>
</div>
