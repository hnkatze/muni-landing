---
---

<div id="contact-form-wrapper" class="reveal-left">
  <p class="text-sm font-semibold uppercase tracking-widest text-muni-gold">Escríbenos</p>
  <h2 class="mt-2 text-2xl font-bold text-gov-navy">Ponte en Contacto</h2>
  <p class="mt-2 text-text-secondary">
    Tienes una pregunta o quieres trabajar juntos? Completa el formulario a continuacion o contactanos directamente.
  </p>

  <form id="contact-form" class="mt-8 space-y-5">
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div>
        <label for="name" class="block text-sm font-medium text-text-primary">Nombre</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="Ingresa tu nombre"
          class="mt-1.5 w-full rounded-xl border border-border-warm bg-bg-subtle px-4 py-2.5 text-sm placeholder-text-tertiary focus:border-gov-navy focus:ring-2 focus:ring-gov-navy/10 focus:outline-none transition-colors"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-text-primary">Correo Electronico</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="Ingresa tu correo electronico"
          class="mt-1.5 w-full rounded-xl border border-border-warm bg-bg-subtle px-4 py-2.5 text-sm placeholder-text-tertiary focus:border-gov-navy focus:ring-2 focus:ring-gov-navy/10 focus:outline-none transition-colors"
        />
      </div>
    </div>

    <div>
      <label for="subject" class="block text-sm font-medium text-text-primary">Asunto</label>
      <input
        type="text"
        id="subject"
        name="subject"
        required
        placeholder="Ingresa el asunto"
        class="mt-1.5 w-full rounded-xl border border-border-warm bg-bg-subtle px-4 py-2.5 text-sm placeholder-text-tertiary focus:border-gov-navy focus:ring-2 focus:ring-gov-navy/10 focus:outline-none transition-colors"
      />
    </div>

    <div>
      <label for="message" class="block text-sm font-medium text-text-primary">Mensaje</label>
      <textarea
        id="message"
        name="message"
        required
        placeholder="Ingresa tu mensaje"
        class="mt-1.5 w-full rounded-xl border border-border-warm bg-bg-subtle px-4 py-2.5 text-sm placeholder-text-tertiary focus:border-gov-navy focus:ring-2 focus:ring-gov-navy/10 focus:outline-none transition-colors"
        style="min-height: 150px;"
      ></textarea>
    </div>

    <button
      type="submit"
      class="rounded-full bg-gov-navy px-8 py-2.5 text-sm font-medium text-white hover:bg-gov-navy-light transition-colors duration-200 shadow-md shadow-gov-navy/20"
    >
      Enviar Mensaje
    </button>
  </form>

  <div id="form-feedback" class="mt-4 hidden rounded-lg p-3 text-sm"></div>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const feedback = document.getElementById('form-feedback')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const body = Object.fromEntries(data.entries());

    try {
      const res = await fetch('https://formspree.io/f/YOUR_FORM_ID', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(body),
      });
      if (res.ok) {
        feedback.textContent = 'Listo, Nos Pondremos En Contacto Contigo Pronto.';
        feedback.className = 'mt-4 rounded-xl bg-muni-green/10 p-3 text-sm text-muni-green-dark';
        form.reset();
      } else {
        throw new Error('Error');
      }
    } catch {
      feedback.textContent = 'Hubo un error al enviar el mensaje. Intenta de nuevo.';
      feedback.className = 'mt-4 rounded-xl bg-red-50 p-3 text-sm text-red-700';
    }
  });
</script>
