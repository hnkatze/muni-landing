---
import { Icon } from 'astro-icon/components';
---

<dialog
  id="requirements-modal"
  class="fixed inset-0 m-auto w-[calc(100%-2rem)] max-w-lg max-h-[80vh] rounded-2xl bg-white p-0 shadow-2xl backdrop:bg-black/60 border-0 overflow-hidden"
>
  {/* Header */}
  <div class="sticky top-0 z-10 flex items-center justify-between bg-gov-navy px-6 py-4">
    <h2 id="modal-title" class="text-lg font-bold text-white"></h2>
    <button
      id="modal-close"
      type="button"
      class="flex h-8 w-8 items-center justify-center rounded-full bg-white/10 text-white/80 hover:bg-white/20 hover:text-white transition-colors duration-200"
      aria-label="Cerrar"
    >
      <Icon name="lucide:x" class="h-5 w-5" />
    </button>
  </div>

  {/* Requirements list */}
  <div class="overflow-y-auto p-6" style="max-height: calc(80vh - 64px);">
    <ul id="modal-list" class="space-y-3"></ul>
  </div>
</dialog>

<script>
  const dialog = document.getElementById('requirements-modal') as HTMLDialogElement;
  const modalTitle = document.getElementById('modal-title')!;
  const modalList = document.getElementById('modal-list')!;
  const closeBtn = document.getElementById('modal-close')!;

  document.querySelectorAll('.req-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const title = (btn as HTMLElement).dataset.title || '';
      const requirements: string[] = JSON.parse((btn as HTMLElement).dataset.requirements || '[]');

      modalTitle.textContent = title;
      modalList.innerHTML = requirements
        .map(
          (req, i) =>
            `<li class="flex items-start gap-3 rounded-lg bg-bg-subtle p-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-muni-green text-white text-xs font-bold">${i + 1}</span>
              <span class="text-sm text-text-primary leading-relaxed">${req}</span>
            </li>`
        )
        .join('');

      dialog.showModal();
    });
  });

  closeBtn.addEventListener('click', () => dialog.close());
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });
</script>
