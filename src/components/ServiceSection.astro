---
import { Icon } from 'astro-icon/components';
import type { SubService } from '../types';

interface Props {
  title: string;
  description: string;
  icon: string;
  subServices: SubService[];
  id?: string;
}

const { title, description, icon, subServices, id } = Astro.props;
---

<section id={id} class="reveal border-b border-border-warm py-14">
  <div class="grid grid-cols-1 gap-8 md:grid-cols-5">
    <div class="md:col-span-1 flex items-start justify-center">
      <div class="flex h-20 w-20 items-center justify-center rounded-2xl bg-bg-warm border border-border-warm">
        <Icon name={icon} class="h-10 w-10 text-gov-navy" />
      </div>
    </div>
    <div class="md:col-span-4">
      <h2 class="text-2xl font-bold text-gov-navy">{title}</h2>
      <p class="mt-2 text-text-secondary leading-relaxed">{description}</p>

      <h3 class="mt-6 text-sm font-semibold uppercase tracking-widest text-muni-gold">Requisitos De:</h3>
      <div class="mt-3 grid grid-cols-1 gap-2 md:grid-cols-2">
        {subServices.map((sub) => (
          <button
            type="button"
            class="req-btn rounded-xl border border-border-warm px-4 py-2.5 text-left text-sm font-medium text-gov-navy hover:bg-bg-warm transition-colors duration-200"
            data-title={sub.title}
            data-requirements={JSON.stringify(sub.requirements)}
          >
            {sub.title}
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

