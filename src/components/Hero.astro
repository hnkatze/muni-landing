---
import { Image } from 'astro:assets';
import muniLogo from '../assets/Muni.png';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section class="relative flex min-h-screen flex-col items-center justify-center gap-6 px-4 text-center bg-gradient-to-b from-gov-navy via-gov-navy-light to-gov-teal overflow-hidden">
  <Image
    src={muniLogo}
    alt="Muni"
    width={550}
    height={650}
    class="hero-logo max-w-[220px] md:max-w-[350px] lg:max-w-[450px] h-auto drop-shadow-2xl"
  />
  <h1 class="hero-title text-4xl font-bold uppercase tracking-wider text-white lg:text-6xl">
    {title}
  </h1>
  <p class="hero-subtitle text-lg text-white/70 max-w-2xl">
    Comprometidos con el bienestar y progreso de nuestra comunidad
  </p>

  <div class="hero-ctas mt-4 flex flex-wrap gap-4 justify-center">
    <a href="/servicios" class="px-8 py-3 bg-muni-green hover:bg-muni-green-dark text-white font-semibold rounded-full transition-colors duration-200 shadow-lg">
      Conocer Servicios
    </a>
    <a href="/nosotros" class="px-8 py-3 border-2 border-white/30 text-white hover:border-white/60 font-semibold rounded-full transition-colors duration-200">
      Sobre Nosotros
    </a>
  </div>

  {/* Scroll indicator */}
  <div class="absolute bottom-8 animate-bounce">
    <svg class="h-6 w-6 text-white/50" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const tl = gsap.timeline({ delay: 0.3 });

  tl.from('.hero-logo', { y: 40, scale: 0.9, duration: 1, ease: 'power3.out' })
    .from('.hero-title', { clipPath: 'inset(0 100% 0 0)', duration: 1.2, ease: 'power4.out' }, 0.3)
    .from('.hero-subtitle', { y: 20, duration: 0.8, ease: 'power2.out' }, 0.6)
    .from('.hero-ctas > *', { y: 30, stagger: 0.15, duration: 0.8, ease: 'power2.out' }, 0.8);
</script>
