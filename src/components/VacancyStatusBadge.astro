---
export type VacancyStatus = 'Abierta' | 'Por cerrar' | 'Cerrada';

interface Props {
  status: VacancyStatus;
}

const { status } = Astro.props;

const variants: Record<VacancyStatus, { classes: string; icon: string }> = {
  Abierta: {
    classes: 'bg-green-100 text-green-800 border border-green-200',
    icon: '●',
  },
  'Por cerrar': {
    classes: 'bg-amber-100 text-amber-800 border border-amber-200',
    icon: '◐',
  },
  Cerrada: {
    classes: 'bg-gray-100 text-gray-600 border border-gray-200',
    icon: '○',
  },
};

const { classes, icon } = variants[status];
---

<span
  class:list={['inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold', classes]}
  aria-label={`Estado: ${status}`}
>
  <span aria-hidden="true">{icon}</span>
  {status}
</span>
