---
import { Icon } from 'astro-icon/components';

const actions = [
  { label: 'Trámites',       icon: 'lucide:clipboard-list', href: '/servicios',     accent: false },
  { label: 'Empleo',         icon: 'lucide:briefcase',      href: '/empleo',        accent: false },
  { label: 'Transparencia',  icon: 'lucide:eye',            href: '/transparencia', accent: false },
  { label: 'Mapa',           icon: 'lucide:map-pin',        href: '/mapa',          accent: false },
  { label: 'Noticias',       icon: 'lucide:newspaper',      href: '/noticias',      accent: false },
  { label: 'Emergencias',    icon: 'lucide:siren',          href: '/emergencias',   accent: true  },
] as const;
---

<div class="hero-enter hero-enter-5 w-full max-w-3xl mx-auto px-4 pb-8">
  <nav aria-label="Acciones rápidas">
    <ul
      class="grid grid-cols-3 gap-3 sm:grid-cols-6"
      role="list"
    >
      {actions.map((action) => (
        <li>
          <a
            href={action.href}
            class:list={[
              'flex min-h-[56px] flex-col items-center justify-center gap-1.5 rounded-2xl border px-2 py-3 text-center transition-all duration-200',
              action.accent
                ? 'border-red-200 bg-red-50 text-red-700 hover:bg-red-100 hover:border-red-300 hover:shadow-sm'
                : 'border-border-warm bg-white/80 text-gov-navy hover:bg-bg-warm hover:border-gov-navy/20 hover:shadow-sm',
            ]}
          >
            <Icon name={action.icon} class="h-5 w-5 shrink-0" aria-hidden="true" />
            <span class="text-xs font-semibold leading-tight">{action.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
</div>
