<section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
  <div class="reveal relative overflow-hidden rounded-3xl bg-gov-navy px-8 py-14 text-center lg:px-16">
    {/* Decorative elements */}
    <div class="absolute top-0 right-0 h-64 w-64 rounded-full bg-gov-teal/10 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 h-48 w-48 rounded-full bg-muni-gold/10 blur-3xl"></div>

    <div class="relative">
      <p class="text-sm font-semibold uppercase tracking-widest text-muni-gold">Estamos para servirte</p>
      <h2 class="mt-3 text-3xl font-bold text-white lg:text-4xl">
        ¿Necesitás realizar un trámite?
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-white/60 leading-relaxed">
        Consultá los requisitos de cada departamento y acercate a nuestras oficinas. Estamos listos para ayudarte.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href="/servicios"
          class="rounded-full bg-white px-8 py-3 text-sm font-semibold text-gov-navy hover:bg-bg-warm transition-colors duration-200 shadow-lg"
        >
          Ver Servicios y Requisitos
        </a>
        <a
          href="/contact"
          class="rounded-full border border-white/20 px-8 py-3 text-sm font-semibold text-white hover:bg-white/10 transition-colors duration-200"
        >
          Contactanos
        </a>
      </div>
    </div>
  </div>
</section>
