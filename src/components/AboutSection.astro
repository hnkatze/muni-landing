---
import { Image } from 'astro:assets';
import bonitoMap from '../assets/Bonitomap.svg';

interface Props {
  title: string;
  content: string;
}

const { title, content } = Astro.props;
---

<section id="about-section" class="mx-auto max-w-7xl px-4 py-16 lg:py-24 sm:px-6 lg:px-8">
  <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-2">
    <div class="about-image flex items-center justify-center rounded-2xl bg-gradient-to-br from-gov-navy to-gov-teal p-10 shadow-xl ring-4 ring-black/20">
      <Image
        src={bonitoMap}
        alt="Mapa de Bonito Oriental"
        width={350}
        height={400}
        class="max-h-[350px] w-auto drop-shadow-lg"
      />
    </div>
    <div class="about-content">
      <h2 class="text-3xl font-bold text-gov-navy lg:text-4xl">{title}</h2>
      <div class="mt-3 h-1 w-16 rounded-full bg-muni-gold"></div>
      <p class="mt-6 text-lg leading-relaxed text-text-secondary">{content}</p>

      {/* Stat badges */}
      <div class="about-stats mt-8 flex flex-wrap gap-3">
        <span class="inline-block rounded-full bg-gov-navy/5 px-4 py-1.5 text-sm font-medium text-gov-navy">Fundado 1860</span>
        <span class="inline-block rounded-full bg-gov-navy/5 px-4 py-1.5 text-sm font-medium text-gov-navy">5+ Departamentos</span>
        <span class="inline-block rounded-full bg-gov-navy/5 px-4 py-1.5 text-sm font-medium text-gov-navy">100+ Proyectos</span>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const trigger = '#about-section';

  gsap.from('.about-image', {
    scrollTrigger: { trigger, start: 'top 80%' },
    x: -80, duration: 1, ease: 'power3.out',
  });

  gsap.from('.about-content', {
    scrollTrigger: { trigger, start: 'top 80%' },
    x: 80, duration: 1, ease: 'power3.out',
  });

  gsap.from('.about-stats > *', {
    scrollTrigger: { trigger: '.about-stats', start: 'top 90%' },
    y: 20, scale: 0.9, stagger: 0.1, duration: 0.6, ease: 'power2.out',
  });
</script>
