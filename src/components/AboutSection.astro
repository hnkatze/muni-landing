---
import { Image } from 'astro:assets';
import bonitoMap from '../assets/Bonitomap.svg';

interface Props {
  title: string;
  content: string;
}

const { title, content } = Astro.props;
---

<section id="about-section" class="mx-auto max-w-7xl px-4 py-20 lg:py-28 sm:px-6 lg:px-8">
  <div class="grid grid-cols-1 items-center gap-16 md:grid-cols-2">
    <div class="reveal-left flex items-center justify-center rounded-3xl bg-bg-warm p-10 border border-border-warm">
      <Image
        src={bonitoMap}
        alt="Mapa de Bonito Oriental"
        width={350}
        height={400}
        class="max-h-[350px] w-auto"
      />
    </div>
    <div class="reveal-right">
      <p class="text-sm font-semibold uppercase tracking-widest text-muni-gold">Conócenos</p>
      <h2 class="mt-2 text-3xl font-bold text-gov-navy lg:text-4xl">{title}</h2>
      <p class="mt-6 text-lg leading-relaxed text-text-secondary">{content}</p>

      {/* Stat badges */}
      <div class="mt-8 flex flex-wrap gap-3">
        <span class="reveal-scale delay-1 inline-block rounded-full bg-bg-warm border border-border-warm px-4 py-1.5 text-sm font-medium text-earth">Fundado 1860</span>
        <span class="reveal-scale delay-2 inline-block rounded-full bg-bg-warm border border-border-warm px-4 py-1.5 text-sm font-medium text-earth">5+ Departamentos</span>
        <span class="reveal-scale delay-3 inline-block rounded-full bg-bg-warm border border-border-warm px-4 py-1.5 text-sm font-medium text-earth">100+ Proyectos</span>
      </div>
    </div>
  </div>
</section>

