---
import { Image } from 'astro:assets';
import bonitoMap from '../assets/Bonitomap.svg';

interface Props {
  title: string;
  content: string;
  variant?: 'full' | 'compact';
}

const { title, content, variant = 'full' } = Astro.props;
---

{variant === 'compact' ? (
  <section id="about-section" class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="reveal flex flex-col items-start gap-4 rounded-3xl border border-border-warm bg-bg-warm px-8 py-8 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold uppercase tracking-widest text-muni-gold">Conócenos</p>
        <h2 class="mt-1 text-xl font-bold text-gov-navy lg:text-2xl">{title}</h2>
        <p class="mt-3 text-sm leading-relaxed text-text-secondary line-clamp-2">{content}</p>
      </div>
      <a
        href="/nosotros"
        class="shrink-0 mt-2 sm:mt-0 inline-flex items-center gap-2 rounded-full border border-gov-navy px-6 py-2.5 text-sm font-semibold text-gov-navy hover:bg-gov-navy hover:text-white transition-colors duration-200"
      >
        Conoce más sobre nosotros
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </section>
) : (
  <section id="about-section" class="mx-auto max-w-7xl px-4 py-20 lg:py-28 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 items-center gap-16 md:grid-cols-2">
      <div class="reveal-left flex items-center justify-center rounded-3xl bg-bg-warm p-10 border border-border-warm">
        <Image
          src={bonitoMap}
          alt="Mapa de Bonito Oriental"
          width={350}
          height={400}
          class="max-h-[350px] w-auto"
        />
      </div>
      <div class="reveal-right">
        <p class="text-sm font-semibold uppercase tracking-widest text-muni-gold">Conócenos</p>
        <h2 class="mt-2 text-3xl font-bold text-gov-navy lg:text-4xl">{title}</h2>
        <p class="mt-6 text-lg leading-relaxed text-text-secondary">{content}</p>

        {/* Stat badges */}
        <div class="mt-8 flex flex-wrap gap-3">
          <span class="reveal-scale delay-1 inline-block rounded-full bg-bg-warm border border-border-warm px-4 py-1.5 text-sm font-medium text-earth">Fundado 1860</span>
          <span class="reveal-scale delay-2 inline-block rounded-full bg-bg-warm border border-border-warm px-4 py-1.5 text-sm font-medium text-earth">5+ Departamentos</span>
          <span class="reveal-scale delay-3 inline-block rounded-full bg-bg-warm border border-border-warm px-4 py-1.5 text-sm font-medium text-earth">100+ Proyectos</span>
        </div>
      </div>
    </div>
  </section>
)}

