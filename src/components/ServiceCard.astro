---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  icon: string;
  href: string;
}

const { title, description, icon, href } = Astro.props;
---

<div class="tilt-card reveal flex w-full flex-col items-center rounded-3xl bg-white p-8 border border-border-warm shadow-sm transition-shadow duration-300 hover:shadow-xl hover:shadow-gov-navy/8">
  <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-bg-warm">
    <Icon name={icon} class="h-8 w-8 text-gov-navy" />
  </div>
  <h3 class="mt-5 text-lg font-bold text-gov-navy">{title}</h3>
  <p class="mt-2 flex-1 text-center text-sm text-text-secondary leading-relaxed">{description}</p>
  <a
    href={href}
    class="mt-5 inline-block rounded-full bg-gov-navy px-6 py-2 text-sm font-medium text-white hover:bg-gov-navy-light transition-colors duration-200"
  >
    Ver Mas
  </a>
</div>
