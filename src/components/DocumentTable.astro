---
/**
 * DocumentTable — accessible data table for transparency disclosures.
 * Renders <table> with <caption>, <th scope="col"> per column, and an
 * empty-state row when `rows` is empty.
 */

interface Props {
  /** Visible caption describing what the table contains (required for a11y) */
  caption: string;
  /** Column header labels in display order */
  columns: string[];
  /** Data rows — keys should match column labels or any string set */
  rows: Record<string, string>[];
  /** Optional: array of row keys aligned to `columns` for custom key access */
  rowKeys?: string[];
}

const { caption, columns, rows, rowKeys } = Astro.props;

// Derive key list: if rowKeys provided use them, otherwise slugify column labels
const keys: string[] = rowKeys ?? columns.map((col) =>
  col.toLowerCase().replace(/\s+/g, '_').replace(/[áéíóú]/g, (c) =>
    ({ á: 'a', é: 'e', í: 'i', ó: 'o', ú: 'u' })[c] ?? c
  )
);
---

<div class="overflow-x-auto rounded-2xl border border-border-warm shadow-sm">
  <table class="min-w-full divide-y divide-border-warm bg-white text-sm">
    <caption class="bg-bg-warm px-6 py-3 text-left text-xs font-semibold uppercase tracking-widest text-text-secondary">
      {caption}
    </caption>
    <thead class="bg-bg-warm">
      <tr>
        {columns.map((col) => (
          <th
            scope="col"
            class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gov-navy"
          >
            {col}
          </th>
        ))}
      </tr>
    </thead>
    <tbody class="divide-y divide-border-warm">
      {rows.length === 0 ? (
        <tr>
          <td
            colspan={columns.length}
            class="px-6 py-8 text-center text-sm text-text-tertiary italic"
          >
            Sin registros disponibles
          </td>
        </tr>
      ) : (
        rows.map((row) => (
          <tr class="hover:bg-bg-subtle transition-colors duration-150">
            {keys.map((key) => (
              <td class="px-6 py-4 text-text-primary whitespace-nowrap">
                {row[key] ?? '—'}
              </td>
            ))}
          </tr>
        ))
      )}
    </tbody>
  </table>
</div>
