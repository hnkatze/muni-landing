---
import { Icon } from 'astro-icon/components';
import type { CollectionEntry } from 'astro:content';
import type { NoticiaCategory } from '../types/index';

interface Props {
  entry: CollectionEntry<'noticias'>;
  featured?: boolean;
}

const { entry, featured = false } = Astro.props;
const { title, excerpt, publishedAt, category, author, image } = entry.data;

const slug = entry.data.slug ?? entry.id;

const categoryConfig: Record<
  NoticiaCategory,
  { label: string; icon: string; color: string }
> = {
  comunicado: { label: 'Comunicado', icon: 'lucide:megaphone', color: 'bg-gov-teal/10 text-gov-teal' },
  evento: { label: 'Evento', icon: 'lucide:calendar-days', color: 'bg-muni-gold/10 text-earth' },
  obra: { label: 'Obra', icon: 'lucide:hard-hat', color: 'bg-muni-green/10 text-muni-green-dark' },
  alerta: { label: 'Alerta', icon: 'lucide:triangle-alert', color: 'bg-red-50 text-red-600' },
  transparencia: { label: 'Transparencia', icon: 'lucide:file-text', color: 'bg-gov-navy/8 text-gov-navy' },
};

const cat = categoryConfig[category];

const publishedFormatted = publishedAt.toLocaleDateString('es-HN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article
  class:list={[
    'flex flex-col rounded-3xl bg-white border border-border-warm',
    'hover:-translate-y-1 hover:shadow-lg hover:shadow-gov-navy/5 transition-all duration-300',
    featured && 'ring-2 ring-muni-gold/30',
  ]}
>
  {image && (
    <div class="overflow-hidden rounded-t-3xl">
      <img
        src={image.src}
        alt={image.alt}
        class="h-48 w-full object-cover transition-transform duration-500 hover:scale-105"
        loading="lazy"
        decoding="async"
      />
    </div>
  )}

  <div class="flex flex-1 flex-col p-6">
    {/* Category badge */}
    <div class="flex items-center gap-2">
      <span class:list={['inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium', cat.color]}>
        <Icon name={cat.icon} class="h-3.5 w-3.5" aria-hidden="true" />
        {cat.label}
      </span>
      {featured && (
        <span class="inline-flex items-center gap-1 rounded-full bg-muni-gold/15 px-2.5 py-0.5 text-xs font-medium text-earth">
          <Icon name="lucide:star" class="h-3 w-3" aria-hidden="true" />
          Destacado
        </span>
      )}
    </div>

    {/* Title */}
    <h3 class="mt-3 text-base font-bold text-gov-navy leading-snug">
      <a
        href={`/noticias/${slug}`}
        class="hover:text-gov-teal transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gov-teal"
      >
        {title}
      </a>
    </h3>

    {/* Excerpt */}
    <p class="mt-2 flex-1 text-sm text-text-secondary leading-relaxed line-clamp-3">
      {excerpt}
    </p>

    {/* Footer: date + author */}
    <div class="mt-4 flex items-center justify-between border-t border-border-warm pt-4">
      <div class="flex items-center gap-1.5 text-xs text-text-tertiary">
        <Icon name="lucide:calendar" class="h-3.5 w-3.5 shrink-0" aria-hidden="true" />
        <time datetime={publishedAt.toISOString().split('T')[0]}>
          {publishedFormatted}
        </time>
      </div>
      {author && (
        <div class="flex items-center gap-1.5 text-xs text-text-tertiary">
          <Icon name="lucide:user" class="h-3.5 w-3.5 shrink-0" aria-hidden="true" />
          <span>{author}</span>
        </div>
      )}
    </div>
  </div>
</article>
