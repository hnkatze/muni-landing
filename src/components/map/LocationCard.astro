---
import { CATEGORY_LABELS, CATEGORY_COLORS } from '../../types/map';
import type { MapPoint } from '../../types/map';

interface Props {
  point: MapPoint;
}

const { point } = Astro.props;
const label = CATEGORY_LABELS[point.category];
const colors = CATEGORY_COLORS[point.category];
---

<article
  class="rounded-xl border border-border-warm bg-white p-4 shadow-sm hover:shadow-md transition-shadow duration-200"
  data-point-id={point.id}
  data-category={point.category}
>
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-sm font-semibold text-text-primary leading-snug">{point.name}</h3>
    <span
      class:list={['shrink-0 rounded-full px-2 py-0.5 text-xs font-medium', colors.bg, colors.text]}
    >
      {label}
    </span>
  </div>

  {point.description && (
    <p class="mt-2 text-xs text-text-secondary leading-relaxed">{point.description}</p>
  )}

  <dl class="mt-3 space-y-1 text-xs text-text-secondary">
    {point.address && (
      <div class="flex items-start gap-2">
        <dt class="sr-only">Dirección</dt>
        <svg class="mt-0.5 h-3.5 w-3.5 shrink-0 text-text-tertiary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
        </svg>
        <dd>{point.address}</dd>
      </div>
    )}
    {point.phone && (
      <div class="flex items-center gap-2">
        <dt class="sr-only">Teléfono</dt>
        <svg class="h-3.5 w-3.5 shrink-0 text-text-tertiary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
        </svg>
        <dd>
          <a href={`tel:${point.phone}`} class="hover:text-gov-navy transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-gov-navy rounded">
            {point.phone}
          </a>
        </dd>
      </div>
    )}
    {point.hours && (
      <div class="flex items-start gap-2">
        <dt class="sr-only">Horario</dt>
        <svg class="mt-0.5 h-3.5 w-3.5 shrink-0 text-text-tertiary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <dd>{point.hours}</dd>
      </div>
    )}
    {point.website && (
      <div class="flex items-center gap-2">
        <dt class="sr-only">Sitio web</dt>
        <svg class="h-3.5 w-3.5 shrink-0 text-text-tertiary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253" />
        </svg>
        <dd>
          <a
            href={point.website}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gov-teal hover:text-gov-navy transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-gov-navy rounded"
          >
            Visitar sitio web
            <span class="sr-only">(abre en nueva ventana)</span>
          </a>
        </dd>
      </div>
    )}
  </dl>
</article>
