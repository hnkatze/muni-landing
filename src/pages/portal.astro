---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import proyectos from '../data/proyectos.json';
---

<Layout title="Portal | Bonito Oriental" description="Proyectos desarrollados por la Municipalidad de Bonito Oriental.">
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="text-center text-sm font-semibold uppercase tracking-widest text-muni-gold">Transparencia</p>
    <h1 class="mt-2 text-center text-3xl font-bold text-gov-navy md:text-5xl">
      Proyectos Desarrollados en 2024
    </h1>

    <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {proyectos.map((proyecto) => (
        <ProjectCard proyecto={proyecto} />
      ))}
    </div>
  </section>
</Layout>
