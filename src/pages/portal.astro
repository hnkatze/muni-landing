---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import proyectos from '../data/proyectos.json';
---

<Layout title="Portal | Bonito Oriental" description="Proyectos desarrollados por la Municipalidad de Bonito Oriental.">
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="text-center text-3xl font-bold uppercase text-gov-navy md:text-5xl">
      PROYECTOS DESARROLLADOS EN 2024
    </h1>

    <div class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4">
      {proyectos.map((proyecto) => (
        <ProjectCard proyecto={proyecto} />
      ))}
    </div>
  </section>
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const cards = document.querySelectorAll('.project-card');
  if (cards.length) {
    gsap.from(cards, {
      scrollTrigger: { trigger: cards[0].parentElement, start: 'top 85%' },
      y: 50, scale: 0.95, stagger: 0.1, duration: 0.7, ease: 'power2.out',
    });
  }
</script>
