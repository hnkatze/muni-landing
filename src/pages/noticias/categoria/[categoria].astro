---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import NoticiaCard from '../../../components/NoticiaCard.astro';
import CategoryFilter from '../../../components/CategoryFilter.astro';
import { Icon } from 'astro-icon/components';
import type { NoticiaCategory } from '../../../types/index';

export async function getStaticPaths() {
  const categories: NoticiaCategory[] = [
    'comunicado',
    'evento',
    'obra',
    'alerta',
    'transparencia',
  ];

  const allNoticias = await getCollection('noticias');

  return categories.map((categoria) => {
    const filtered = allNoticias
      .filter((n) => n.data.category === categoria)
      .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
    return {
      params: { categoria },
      props: { noticias: filtered, categoria },
    };
  });
}

const { noticias, categoria } = Astro.props;

const categoryLabels: Record<NoticiaCategory, string> = {
  comunicado: 'Comunicados',
  evento: 'Eventos',
  obra: 'Obras',
  alerta: 'Alertas',
  transparencia: 'Transparencia',
};

const label = categoryLabels[categoria as NoticiaCategory];
---

<Layout
  title={`${label} | Noticias | Bonito Oriental`}
  description={`Noticias de la categoría ${label} de la Municipalidad de Bonito Oriental.`}
>
  {/* Hero */}
  <section class="bg-gov-navy py-20 px-4">
    <div class="mx-auto max-w-7xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-muni-gold">Noticias</p>
      <h1 class="mt-3 text-4xl font-bold text-white md:text-5xl">{label}</h1>
      <p class="mt-4 text-lg text-white/50 max-w-xl mx-auto">
        Filtrando por categoría: <strong class="text-white/80">{label}</strong>
      </p>
    </div>
  </section>

  {/* Filter + Grid */}
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-8">
      <CategoryFilter currentCategory={categoria as NoticiaCategory} />
    </div>

    {noticias.length === 0 ? (
      <div class="flex flex-col items-center justify-center py-24 text-center">
        <Icon name="lucide:newspaper" class="h-12 w-12 text-text-tertiary mb-4" aria-hidden="true" />
        <p class="text-lg font-semibold text-gov-navy">No hay noticias en esta categoría</p>
        <p class="mt-2 text-sm text-text-secondary">
          <a href="/noticias" class="text-gov-teal hover:underline">Ver todas las noticias</a>
        </p>
      </div>
    ) : (
      <>
        <p class="mb-8 text-sm text-text-secondary" aria-live="polite">
          {noticias.length} {noticias.length === 1 ? 'noticia' : 'noticias'} en {label}
        </p>
        <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
          {noticias.map((entry) => (
            <li>
              <NoticiaCard entry={entry} featured={entry.data.featured} />
            </li>
          ))}
        </ul>
      </>
    )}
  </section>
</Layout>
