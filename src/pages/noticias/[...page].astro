---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import NoticiaCard from '../../components/NoticiaCard.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import { Icon } from 'astro-icon/components';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allNoticias = await getCollection('noticias');
  const sorted = allNoticias.sort(
    (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
  );
  return paginate(sorted, { pageSize: 10 });
}

const { page } = Astro.props;
---

<Layout
  title={`Noticias y Boletín${page.currentPage > 1 ? ` — Página ${page.currentPage}` : ''} | Bonito Oriental`}
  description="Noticias, comunicados, eventos y obras de la Municipalidad de Bonito Oriental."
>
  {/* Hero */}
  <section class="bg-gov-navy py-20 px-4">
    <div class="mx-auto max-w-7xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-muni-gold">Municipalidad de Bonito Oriental</p>
      <h1 class="mt-3 text-4xl font-bold text-white md:text-5xl lg:text-6xl">Noticias y Boletín</h1>
      <p class="mt-4 text-lg text-white/50 max-w-2xl mx-auto">
        Entérate de las últimas novedades, obras, eventos y comunicados oficiales de tu municipio.
      </p>
      <div class="mt-6">
        <a
          href="/rss.xml"
          class="inline-flex items-center gap-2 rounded-full border border-white/20 px-5 py-2 text-sm text-white/70 hover:bg-white/10 transition-colors duration-200"
          aria-label="Suscribirse al boletín RSS"
        >
          <Icon name="lucide:rss" class="h-4 w-4" aria-hidden="true" />
          Suscribirse vía RSS
        </a>
      </div>
    </div>
  </section>

  {/* Filter + Grid */}
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    {/* Category filter */}
    <div class="mb-8">
      <CategoryFilter />
    </div>

    {page.data.length === 0 ? (
      <div class="flex flex-col items-center justify-center py-24 text-center">
        <Icon name="lucide:newspaper" class="h-12 w-12 text-text-tertiary mb-4" aria-hidden="true" />
        <p class="text-lg font-semibold text-gov-navy">No hay noticias disponibles</p>
        <p class="mt-2 text-sm text-text-secondary">Vuelve pronto para ver las últimas novedades.</p>
      </div>
    ) : (
      <>
        <p class="mb-8 text-sm text-text-secondary" aria-live="polite">
          Mostrando {page.start + 1}–{page.end + 1} de {page.total}{' '}
          {page.total === 1 ? 'noticia' : 'noticias'}
        </p>

        <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
          {page.data.map((entry) => (
            <li>
              <NoticiaCard entry={entry} featured={entry.data.featured} />
            </li>
          ))}
        </ul>

        {/* Pagination */}
        {(page.url.prev || page.url.next) && (
          <nav
            class="mt-12 flex items-center justify-between border-t border-border-warm pt-8"
            aria-label="Paginación de noticias"
          >
            {page.url.prev ? (
              <a
                href={page.url.prev}
                class="inline-flex items-center gap-2 rounded-full border border-border-warm px-5 py-2.5 text-sm font-medium text-gov-navy hover:bg-bg-warm transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gov-teal"
              >
                <Icon name="lucide:arrow-left" class="h-4 w-4" aria-hidden="true" />
                Anterior
              </a>
            ) : (
              <span />
            )}

            <span class="text-sm text-text-secondary" aria-current="page">
              Página {page.currentPage} de {page.lastPage}
            </span>

            {page.url.next ? (
              <a
                href={page.url.next}
                class="inline-flex items-center gap-2 rounded-full border border-border-warm px-5 py-2.5 text-sm font-medium text-gov-navy hover:bg-bg-warm transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gov-teal"
              >
                Siguiente
                <Icon name="lucide:arrow-right" class="h-4 w-4" aria-hidden="true" />
              </a>
            ) : (
              <span />
            )}
          </nav>
        )}
      </>
    )}
  </section>
</Layout>
