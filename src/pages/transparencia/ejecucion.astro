---
import Layout from '../../layouts/Layout.astro';
import DocumentTable from '../../components/DocumentTable.astro';
import DownloadButton from '../../components/DownloadButton.astro';
import type { EjecucionRow } from '../../types/transparencia';
import ejecucionData from '../../data/transparencia/ejecucion.json';

const rows = ejecucionData as EjecucionRow[];

const columns = ['Año', 'Período', 'Monto Aprobado', 'Monto Ejecutado', '% Ejecución', 'Documento'];
const rowKeys = ['year', 'trimestre', 'aprobado', 'ejecutado', 'porcentaje', 'pdfUrl'];

const tableRows = rows.map((r) => ({
  year: String(r.year),
  trimestre: r.trimestre,
  aprobado: r.aprobado,
  ejecutado: r.ejecutado,
  porcentaje: r.porcentaje,
  pdfUrl: r.pdfUrl ? 'Disponible' : 'No disponible',
}));
---

<Layout
  title="Ejecución Presupuestaria | Transparencia | Bonito Oriental"
  description="Informes de ejecución presupuestaria — Municipalidad de Bonito Oriental."
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <nav aria-label="Ubicación actual" class="mb-6 text-sm text-text-secondary">
      <ol class="flex items-center gap-1">
        <li><a href="/transparencia" class="hover:text-gov-navy transition-colors">Transparencia</a></li>
        <li aria-hidden="true" class="text-text-tertiary">›</li>
        <li class="text-gov-navy font-medium" aria-current="page">Ejecución Presupuestaria</li>
      </ol>
    </nav>

    <div class="mb-8">
      <p class="text-sm font-semibold uppercase tracking-widest text-muni-gold">Transparencia Activa</p>
      <h1 class="mt-1 text-3xl font-bold text-gov-navy md:text-4xl">Ejecución Presupuestaria</h1>
      <p class="mt-3 max-w-2xl text-sm text-text-secondary leading-relaxed">
        Informes trimestrales de ejecución del presupuesto municipal. Refleja
        el avance en la ejecución de los recursos asignados por rubro.
      </p>
    </div>

    <DocumentTable
      caption="Ejecución presupuestaria por trimestre"
      columns={columns}
      rows={tableRows}
      rowKeys={rowKeys}
    />

    {rows.filter((r) => r.pdfUrl).length > 0 && (
      <div class="mt-8">
        <h2 class="mb-4 text-lg font-semibold text-gov-navy">Documentos para Descarga</h2>
        <ul class="flex flex-wrap gap-3" aria-label="Informes de ejecución disponibles">
          {rows.filter((r) => r.pdfUrl).map((r) => (
            <li>
              <DownloadButton
                label={`Descargar ${r.trimestre} ${r.year} — PDF`}
                href={r.pdfUrl!}
              />
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>
</Layout>
