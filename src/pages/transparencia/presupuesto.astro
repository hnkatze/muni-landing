---
import Layout from '../../layouts/Layout.astro';
import DocumentTable from '../../components/DocumentTable.astro';
import DownloadButton from '../../components/DownloadButton.astro';
import type { PresupuestoRow } from '../../types/transparencia';
import presupuestoData from '../../data/transparencia/presupuesto.json';

const rows = presupuestoData as PresupuestoRow[];

const columns = ['Año', 'Descripción', 'Monto Aprobado', 'Documento'];
const rowKeys = ['year', 'description', 'amount', 'pdfUrl'];

// Build display rows (convert pdfUrl to a placeholder text for the table cell)
const tableRows = rows.map((r) => ({
  year: String(r.year),
  description: r.description,
  amount: r.amount,
  pdfUrl: r.pdfUrl ? 'Disponible' : 'No disponible',
}));
---

<Layout
  title="Presupuesto Municipal | Transparencia | Bonito Oriental"
  description="Presupuestos municipales aprobados — Municipalidad de Bonito Oriental."
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <!-- Breadcrumb -->
    <nav aria-label="Ubicación actual" class="mb-6 text-sm text-text-secondary">
      <ol class="flex items-center gap-1">
        <li><a href="/transparencia" class="hover:text-gov-navy transition-colors">Transparencia</a></li>
        <li aria-hidden="true" class="text-text-tertiary">›</li>
        <li class="text-gov-navy font-medium" aria-current="page">Presupuesto Municipal</li>
      </ol>
    </nav>

    <div class="mb-8">
      <p class="text-sm font-semibold uppercase tracking-widest text-muni-gold">Transparencia Activa</p>
      <h1 class="mt-1 text-3xl font-bold text-gov-navy md:text-4xl">Presupuesto Municipal</h1>
      <p class="mt-3 max-w-2xl text-sm text-text-secondary leading-relaxed">
        Presupuestos anuales aprobados por el Cabildo Municipal conforme a la
        normativa de la Ley Orgánica del Presupuesto.
      </p>
    </div>

    <DocumentTable
      caption="Presupuestos municipales aprobados por año"
      columns={columns}
      rows={tableRows}
      rowKeys={rowKeys}
    />

    <!-- PDF download links -->
    {rows.filter((r) => r.pdfUrl).length > 0 && (
      <div class="mt-8">
        <h2 class="mb-4 text-lg font-semibold text-gov-navy">Documentos para Descarga</h2>
        <ul class="flex flex-wrap gap-3" aria-label="Documentos de presupuesto disponibles">
          {rows.filter((r) => r.pdfUrl).map((r) => (
            <li>
              <DownloadButton
                label={`Descargar Presupuesto ${r.year} — PDF`}
                href={r.pdfUrl!}
              />
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>
</Layout>
